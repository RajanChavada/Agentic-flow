# Backend environment variables
# Copy to .env and fill in your values

# CORS: comma-separated list of allowed frontend origins
# Local dev only:
FRONTEND_ORIGINS=http://localhost:3000
# Local + production:
# FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Uvicorn server
HOST=0.0.0.0
PORT=8000

# Stripe API credentials
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
STRIPE_STARTER_PRICE_ID=price_starter_123
STRIPE_PRO_PRICE_ID=price_pro_123
STRIPE_CUSTOMER_PORTAL_ID=cs_test_xxx (optional, for custom portal configuration)

# Frontend URL (used for redirects)
FRONTEND_URL=http://localhost:3000

# Supabase credentials (for subscription management)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

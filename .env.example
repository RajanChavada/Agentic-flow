# Neurovn Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend (Render) ─────────────────────────────────────────────────────

# FastAPI server
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated). Include localhost and production frontend URLs.
FRONTEND_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Stripe configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Price IDs from Stripe Dashboard (Products → Prices → copy the Price ID)
STRIPE_STARTER_PRICE_ID=price_starter_1234567890
STRIPE_PRO_PRICE_ID=price_pro_1234567890

# Customer Portal (optional but recommended - configure in Stripe Dashboard)
STRIPE_CUSTOMER_PORTAL_ID=bpc_1TEKwhJ7lA8dxTPzSCgi1pr2

# Supabase (backend needs service role key for database access)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# Also set SUPABASE_URL in Render environment (or use dotenv)
SUPABASE_URL=https://your-project.supabase.co

# LLM configuration for NL-to-schema generation (if using)
OPENAI_API_KEY=your-openai-api-key-here
SCHEMA_GEN_MODEL=gpt-4o-mini
SCAFFOLD_MODEL=gpt-4o-mini


# ── Frontend (Vercel) ────────────────────────────────────────────────────
# These must be set in Vercel dashboard as environment variables (Preview + Production)

# Backend API URL
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Stripe configuration (publishable key only - safe to expose to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Price IDs (same as backend values)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_1234567890
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_1234567890

# Paywall toggle (set to false during development if needed)
NEXT_PUBLIC_PAYWALL_ENABLED=true


# ── Local Development ────────────────────────────────────────────────────
# For local development, create a .env file with your actual values.
# Never commit .env to version control.
